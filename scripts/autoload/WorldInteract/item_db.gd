# --- 🌟 全局统一的数据查询接口 ---
func get_item_base(item_id: String) -> Dictionary:
	if not ITEMS.has(item_id):
		push_error("ItemDB 找不到物品 ID: " + item_id)
		return {}
		
	var data = ITEMS[item_id].duplicate() 
	
	# 自动加载图片逻辑，注意这里把 key 也改成了中文的 "图标"
	var img_path = ICON_BASE_PATH + item_id + ".png" 
	if ResourceLoader.exists(img_path):
		data["图标"] = load(img_path)
	else:
		data["图标"] = preload("res://assets/icons/ui/全部标签.png") 
		
	return data
